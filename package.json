{
  "name": "ai-efficiency",
  "version": "1.0.0",
  "description": "AI Efficiency Manager - personal productivity tool",
  "main": "src/main/index.js",
  "scripts": {
    "start": "electron .",
    "dev": "concurrently \"webpack serve --config webpack.renderer.js\" \"wait-on http://localhost:9000 && electron .\"",
    "build:renderer": "webpack --config webpack.renderer.js --mode production",
    "build": "npm run build:renderer && electron-builder",
    "test": "jest",
    "postinstall": "electron-rebuild -f -w better-sqlite3"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "cytoscape": "^3.30.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "@babel/preset-react": "^7.23.0",
    "babel-loader": "^9.1.0",
    "concurrently": "^8.2.0",
    "css-loader": "^6.10.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0",
    "html-webpack-plugin": "^5.6.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "style-loader": "^3.3.0",
    "wait-on": "^7.2.0",
    "webpack": "^5.90.0",
    "webpack-cli": "^5.1.0",
    "webpack-dev-server": "^5.0.0",
    "@electron/rebuild": "^3.6.0",
    "postcss": "^8.4.0",
    "postcss-loader": "^8.1.0",
    "autoprefixer": "^10.4.0"
  },
  "build": {
    "appId": "com.ai-efficiency.app",
    "productName": "AI Efficiency",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/main/**/*",
      "dist-renderer/**/*",
      "resources/**/*"
    ],
    "extraResources": [
      {
        "from": "resources/whisper",
        "to": "whisper"
      },
      {
        "from": "resources/models",
        "to": "models"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "resources/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "keywords": [
    "electron",
    "react",
    "ai",
    "calendar",
    "knowledge-graph"
  ],
  "author": "",
  "license": "UNLICENSED",
  "private": true
}